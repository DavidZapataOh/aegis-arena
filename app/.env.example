# ─────────────────────────────────────────────────────────────────────────────
# AegisArena — app environment
# Copy to `.env.local`. Everything is OPTIONAL: with nothing set the app runs in
# demo mode (canned reentrancy claim) + simulated settlement, but the Foundry
# proof-of-exploit sandbox is always real.
# ─────────────────────────────────────────────────────────────────────────────

# --- AI agents (real auditing) ---
# Without this, agents run in deterministic demo mode.
ANTHROPIC_API_KEY=
# Model + reasoning effort for the auditor agents.
AGENT_MODEL=claude-opus-4-8
AGENT_EFFORT=medium

# --- Foundry sandbox ---
# Path to the sibling /sandbox project and the forge binary.
SANDBOX_DIR=../sandbox
FORGE_BIN=forge

# --- Static-analysis grounding (contracts) ---
# Slither (Trail of Bits) feeds high-recall leads to the contract agents; the agents
# must still PROVE each one with a Foundry PoC. Best-effort: if unavailable, it's skipped.
# Install: pipx install slither-analyzer. Use an absolute path if ~/.local/bin isn't on PATH.
SLITHER_BIN=slither

# --- Monad testnet ---
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_RPC=https://testnet-rpc.monad.xyz

# --- On-chain settlement (optional) ---
# Set both to pay agents for real. Deploy contracts first (see /contracts).
# The verifier key signs submitFinding/resolveFinding/closeAudit AND escrows the bounty.
AUDIT_ARENA_ADDRESS=
VERIFIER_PRIVATE_KEY=
# Bounty escrowed per audit (MON) in on-chain mode.
DEFAULT_BOUNTY_MON=0.05
# Optional: payout addresses for the 3 contract agents (comma-separated). Defaults to anvil keys.
AGENT_ADDRESSES=
# Optional: payout addresses for the 3 web/API agents (comma-separated). Defaults to anvil keys.
WEB_AGENT_ADDRESSES=

# Note: web/API auditing has no extra config. It runs SSRF-guarded, non-destructive,
# OWASP-aligned HTTP probes against targets you confirm you're authorized to test.
