# Copy to .env and `source .env` before deploying to Monad testnet.
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
MONAD_MAINNET_RPC=https://rpc-mainnet.monadinfra.com

# Deployer + verifier (the verifier settles findings; can be the same key for the demo).
DEPLOYER_PRIVATE_KEY=0x...
VERIFIER_ADDRESS=0x...

# Optional, for `forge verify-contract`
EXPLORER_API_KEY=
